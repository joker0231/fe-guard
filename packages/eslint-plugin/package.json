{
  "name": "eslint-plugin-fe-guard",
  "version": "0.1.1",
  "description": "ESLint plugin for Frontend Guard - AI代码编译级防御",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "eslint": ">=9.0.0",
    "typescript": ">=5.0.0"
  },
  "dependencies": {
    "@typescript-eslint/utils": "^8.0.0",
    "@typescript-eslint/typescript-estree": "^8.0.0"
  },
  "keywords": ["eslint", "eslintplugin", "frontend-guard", "ai", "react"]
}