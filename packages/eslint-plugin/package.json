{
  "name": "eslint-plugin-fe-guard",
  "version": "0.3.9",
  "description": "ESLint plugin for Frontend Guard - AI\u4ee3\u7801\u7f16\u8bd1\u7ea7\u9632\u5fa1",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "eslint": ">=9.0.0",
    "typescript": ">=5.0.0"
  },
  "dependencies": {
    "@typescript-eslint/utils": "^8.0.0",
    "@typescript-eslint/typescript-estree": "^8.0.0"
  },
  "keywords": [
    "eslint",
    "eslintplugin",
    "frontend-guard",
    "ai",
    "react"
  ]
}
